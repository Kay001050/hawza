    { "name": "مكتبة الطفل الموالي", "short_name": "الطفل",    "url": "/book/?lib=child&source=shortcut",        "description": "مكتبة خاصة بالطفل الموالي",             "icons": [{ "src": "/book/icons/icon-96.png", "sizes": "96x96", "type": "image/png" }] },
