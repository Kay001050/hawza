  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://hawza.netlify.app/book/manifest.json"
    }
  ],

  "scope_extensions": [
    { "origin": "https://hawza.netlify.app" },
    { "origin": "https://*.hawza.netlify.app" }
  ],

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "share_target": {
    "action": "/book/?action=share",
    "method": "GET",
    "params": {
      "title": "title",
      "text":  "text",
      "url":   "url"
    }
  },

  "file_handlers": [
    {
      "action": "/book/?action=open-file",
      "accept": {
        "application/pdf": [".pdf"],
        "application/epub+zip": [".epub"],
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": [".docx"]
      }
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+hawza",
      "url": "/book/?protocol=%s"
    }
  ],

  "edge_side_panel": {
    "preferred_width": 400
  },

  "widgets": [
    {
      "name": "نور الحوزة",
      "short_name": "آخر الكتب",
      "description": "أحدث الكتب في المكتبة الرقمية لنور الحوزة",
      "tag": "latest-books",
      "template": "generic-template",
      "ms_ac_template": "/book/widgets/books-widget.json",
      "data": "/book/widgets/books-data.json",
      "type": "application/json",
      "screenshots": [
        { "src": "/book/icons/screenshot-narrow.png", "sizes": "390x844", "label": "واجهة الكتب" }
      ],
      "icons": [
        { "src": "/book/icons/icon-96.png",  "sizes": "96x96",   "type": "image/png" },
        { "src": "/book/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }
      ],
      "auth": false,
      "update": 3600
    }
  ],

  "handle_links": "preferred",

  "note_taking": {
    "new_note_url": "/book/?action=new-note"
  },

  "periodic_sync": {
    "minimum_interval": 86400,
    "sync_url": "/book/api/sync",
    "tag": "library-sync"
  }
}
